<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>ab66f863-ccc1-4cfe-aadb-e3ebaec490a9</ProjectGuid>
    <ProjectHome>.</ProjectHome>
    <StartupFile>main.py</StartupFile>
    <SearchPath>
    </SearchPath>
    <WorkingDirectory>.</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <Name>AICodeBackend</Name>
    <RootNamespace>AICodeBackend</RootNamespace>
    <InterpreterId>MSBuild|env|$(MSBuildProjectFullPath)</InterpreterId>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="API\CodeAPI.py" />
    <Compile Include="API\LoginAPI.py" />
    <Compile Include="main.py" />
    <Compile Include="Models\CodeModel.py" />
    <Compile Include="Models\LoginModel.py" />
    <Compile Include="Models\UserModel.py" />
    <Compile Include="Modules\ModulesDataLoader\CodeDataLoader.py" />
    <Compile Include="Modules\ModulesTrains\CodeTrain.py" />
    <Compile Include="routes.py" />
    <Compile Include="Server\Common\dbconnection.py" />
    <Compile Include="Services\CodeService.py" />
    <Compile Include="Services\LoginService.py" />
  </ItemGroup>
  <ItemGroup>
    <Interpreter Include="env\">
      <Id>env</Id>
      <Version>3.11</Version>
      <Description>env (Python 3.11 (64-bit))</Description>
      <InterpreterPath>Scripts\python.exe</InterpreterPath>
      <WindowsInterpreterPath>Scripts\pythonw.exe</WindowsInterpreterPath>
      <PathEnvironmentVariable>PYTHONPATH</PathEnvironmentVariable>
      <Architecture>X64</Architecture>
    </Interpreter>
  </ItemGroup>
  <ItemGroup>
    <Content Include="Modules\ModulesData\reviews.csv" />
    <Content Include="Modules\__pycache__\CodeML.cpython-311.pyc" />
    <Content Include="Models\__pycache__\CodeModel.cpython-311.pyc" />
    <Content Include="Models\__pycache__\LoginModel.cpython-311.pyc" />
    <Content Include="Services\__pycache__\CodeService.cpython-311.pyc" />
    <Content Include="Services\__pycache__\LoginService.cpython-311.pyc" />
    <Content Include="settings.ini" />
    <Content Include="requirements.txt" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="API\" />
    <Folder Include="Common\" />
    <Folder Include="Modules\" />
    <Folder Include="Modules\ModulesModels\" />
    <Folder Include="Modules\ModulesData\" />
    <Folder Include="Modules\ModulesTrains\" />
    <Folder Include="Modules\ModulesDataLoader\" />
    <Folder Include="Modules\__pycache__\" />
    <Folder Include="Models\" />
    <Folder Include="Models\__pycache__\" />
    <Folder Include="Server\" />
    <Folder Include="Server\Common\" />
    <Folder Include="Services\" />
    <Folder Include="Services\__pycache__\" />
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
  <!-- Uncomment the CoreCompile target to enable the Build command in
       Visual Studio and specify your pre- and post-build commands in
       the BeforeBuild and AfterBuild targets below. -->
  <!--<Target Name="CoreCompile" />-->
  <Target Name="BeforeBuild">
  </Target>
  <Target Name="AfterBuild">
  </Target>
</Project>